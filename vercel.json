{
  "version": 2,
  "name": "medicine-finder-pro",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "methods": ["GET", "HEAD", "OPTIONS"]
    }
  ],
  "env": {
    "VITE_APP_NAME": "Medicine Finder Pro",
    "VITE_APP_VERSION": "1.0.0",
    "VITE_ENABLE_ANALYTICS": "true",
    "VITE_ENABLE_NOTIFICATIONS": "true",
    "VITE_ENABLE_OFFLINE_SUPPORT": "true"
  },
  "build": {
    "env": {
      "VITE_APP_NAME": "Medicine Finder Pro",
      "VITE_APP_VERSION": "1.0.0"
    }
  },
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
